# ---------------------------------------------------------------------------
# Copy this file to `.env` and add ONE key to run in LIVE mode.
# With no key present the system runs fully offline in MOCK mode.
# Provider preference order is anthropic -> openai -> gemini.
# ---------------------------------------------------------------------------

# Anthropic (Claude) — recommended for this use case
# ANTHROPIC_API_KEY=sk-ant-...

# OpenAI
# OPENAI_API_KEY=sk-...

# Google Gemini
# GEMINI_API_KEY=...

# Optional: force a specific provider even if multiple keys are set
# LLM_PROVIDER=anthropic
